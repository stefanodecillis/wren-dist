# Copy to .env and fill in. NEVER commit .env.
#
# Generate the three secrets with:
#   openssl rand -base64 32   # MASTER_ENCRYPTION_KEY (must decode to exactly 32 bytes)
#   openssl rand -base64 48   # JWT_ACCESS_SECRET
#   openssl rand -base64 48   # JWT_REFRESH_SECRET

# --- Required secrets ---------------------------------------------------------------------

# AES-256-GCM key for everything encrypted at rest (OAuth tokens, API keys). base64 of 32 bytes.
MASTER_ENCRYPTION_KEY=

# JWT signing secrets. Access tokens are short-lived; refresh tokens rotate.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# --- Optional database credentials --------------------------------------------------------
# Defaults match docker-compose. Change all three together if you customize them.
POSTGRES_USER=wren
POSTGRES_PASSWORD=wren
POSTGRES_DB=wren

# --- Tokens / URLs ------------------------------------------------------------------------

JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Public base URL the backend is reached at (used to build OAuth redirect URIs).
# On a LAN, use your host's IP, e.g. http://192.168.1.20:8080
PUBLIC_BASE_URL=http://localhost:8080

# CORS allow-list (comma separated). The apps use native HTTP, so "*" is fine for local use.
CORS_ORIGINS=*

# --- Gmail OAuth (optional here; can also be set per-account in the app) -------------------
# See docs/google-cloud-setup.md. Authorize redirect URI ${PUBLIC_BASE_URL}/accounts/google/callback.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# DATABASE_URL and REDIS_URL are set by docker-compose to reach the postgres/redis services —
# you do not need to set them here.
